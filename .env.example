# =============================================================================
# Kharesiya Knowledge Platform — unified environment
# Copy this file to .env at the repository root and fill in your values.
# =============================================================================

# --- Supabase / PostgreSQL ---
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Auth (shared by Knowledge Hub + RAG) ---
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# --- Knowledge Hub app ---
STORAGE_TYPE="local"
STORAGE_LOCAL_PATH="public/uploads"
S3_BUCKET=""
S3_REGION="us-east-1"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_ENDPOINT=""
NEXT_PUBLIC_APP_NAME="Kharesiya Knowledge Hub"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DEMO_MODE="false"
RAG_SERVICE_URL="http://localhost:8000"

# --- Email automation (weekly training reminders) ---
EMAIL_ENABLED="true"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="noreply@kharesiya.com"
SMTP_FROM_NAME="Kharesiya Knowledge Hub"
CRON_SECRET="generate-a-long-random-secret"

# --- RAG service ---
APP_NAME=Kharesiya RAG Service
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000
HOST=0.0.0.0
PORT=8000

LOCAL_DEV=true
USE_CELERY=false

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_LLM_MODEL=qwen3:8b
OLLAMA_MAX_TOKENS=300
OLLAMA_NUM_CTX=2048

LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=300

VECTOR_STORE=auto
PINECONE_API_KEY=
PINECONE_INDEX_NAME=kharesiya-knowledge
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_DIMENSION=768

# Paths relative to services/rag/ when running locally or in Docker WORKDIR /app
UPLOAD_DIR=./data/uploads
DOCUMENTS_DIR=./data/documents
MAX_UPLOAD_SIZE_MB=50

CHUNK_SIZE=800
CHUNK_OVERLAP=150
DEFAULT_TOP_K=5
CACHE_TTL_SECONDS=300
RATE_LIMIT_PER_MINUTE=60
